# Azure GPU VM configuration for gripper_cv training.
# Copy to .env and fill in your values. .env is gitignored.

# ----- Required -----
# Azure resource group name (will be created if missing).
AZ_RG=gripper-cv-rg

# Azure region. Pick one where you have GPU quota.
# Common T4-friendly regions: eastus, westeurope, southeastasia.
AZ_REGION=eastus

# Name of the VM. Keep it DNS-safe.
AZ_VM_NAME=gripper-gpu

# ----- Optional overrides -----
# VM SKU. Default: 1x T4 16GB (cheapest GPU). Alternatives:
#   Standard_NV6ads_A10_v5  -> 1x A10 24GB (faster, pricier, more common quota)
#   Standard_NC6s_v3        -> 1x V100 16GB (rare quota, only if desperate)
AZ_VM_SIZE=Standard_NC4as_T4_v3

# Ubuntu HPC image = CUDA + NVIDIA drivers pre-installed.
# Do NOT switch to plain Ubuntu unless you're ready to chase driver setup.
AZ_IMAGE=microsoft-dsvm:ubuntu-hpc:2204:latest

# SSH user on the VM.
AZ_ADMIN_USER=azureuser

# Auto-shutdown time in HHMM (local time of the VM region). "2300" = 23:00.
# Set to empty string to disable auto-shutdown.
AZ_AUTOSHUTDOWN_TIME=2300

# Set to 1 to provision a Spot VM (up to 80% cheaper, can be evicted).
AZ_USE_SPOT=0

# Max price per hour for Spot (USD). Default -1 = pay up to pay-as-you-go.
AZ_SPOT_MAX_PRICE=-1
